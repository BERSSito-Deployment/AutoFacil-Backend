# Plantilla para deploy. No ponga secretos reales en este archivo.

# Genere una clave larga y aleatoria para firmar JWT.
AUTOFACIL_CLAVE_SECRETA=reemplace-por-una-clave-larga-y-aleatoria

# Use la URL PostgreSQL que entregue su proveedor.
# Tambien puede definir DATABASE_URL en la plataforma si prefiere.
AUTOFACIL_URL_BASE_DATOS=postgresql+psycopg://USUARIO:CONTRASENA@HOST:5432/NOMBRE_DB

# En produccion evite crear los usuarios demo.
AUTOFACIL_SEMBRAR_DATOS_INICIO=false

# Origenes permitidos para el frontend en formato JSON.
AUTOFACIL_ORIGENES_CORS=["https://tu-frontend.com"]

AUTOFACIL_ALGORITMO_JWT=HS256
AUTOFACIL_MINUTOS_EXPIRACION_TOKEN=480
